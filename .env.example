# Create these in your Slack app's Basic Information / OAuth pages.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_SIGNING_SECRET=your-signing-secret

# Gemini structured extraction. Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
# false sends only likely commitment candidates to Gemini, reducing cost and surveillance risk.
GEMINI_ANALYZE_ALL=false
TIME_ZONE=Asia/Kolkata

# Secondary AI provider. Used only when Gemini fails or is unavailable.
# Create a key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TIMEOUT_MS=15000

# Optional tuning for a fast demo.
NUDGE_INTERVAL_MS=60000
NUDGE_LEAD_MINUTES=30
NUDGE_REPEAT_HOURS=4
DATA_FILE=./data/commitments.json

# Weekly digest: 0=Sunday, 1=Monday. DMs are the privacy-first default.
DIGEST_DAY=1
DIGEST_HOUR=9
ALLOW_CHANNEL_DIGEST=false
DIGEST_CHANNEL_ID=

# Escalation is disabled unless ESCALATION_AFTER_DAYS is greater than 0.
ESCALATION_AFTER_DAYS=0
ESCALATION_MANAGER_USER_ID=
ALLOW_PUBLIC_ESCALATION=false
ESCALATION_CHANNEL_ID=

# MCP sync uses the bundled JSON demo tracker by default.
MCP_DISABLED=false
MCP_SERVER_URL=
MCP_AUTH_TOKEN=
MCP_TOOL_NAME=upsert_commitment
# To use the included Notion-backed MCP server, create a Notion integration,
# share the database with it, then use these settings. Keep MCP_SERVER_URL empty.
# MCP_COMMAND=node
# MCP_ARGS=["scripts/mcp-notion-server.js"]
# NOTION_TOKEN=ntn_your-internal-integration-token
# NOTION_DATA_SOURCE_ID=your-data-source-id
# NOTION_API_VERSION=2026-03-11
# For another custom stdio server:
# MCP_COMMAND=node
# MCP_ARGS=["scripts/mcp-tracker-server.js"]
