{
  "display_information": {
    "name": "FollowThrough",
    "description": "The accountability agent that turns promises into progress.",
    "background_color": "#4A154B"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "FollowThrough",
      "always_online": true
    },
    "agent_view": {
      "agent_description": "I find commitments, track owners and dates, and help the team close the loop.",
      "suggested_prompts": [
        { "title": "My commitments", "message": "Show my open commitments" },
        { "title": "Live context", "message": "context: launch plan" },
        { "title": "Weekly digest", "message": "Show my weekly digest" }
      ]
    },
    "slash_commands": [
      {
        "command": "/followthrough",
        "description": "List and manage tracked commitments",
        "usage_hint": "mine | team | digest | help",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "chat:write",
        "commands",
        "groups:history",
        "im:history",
        "im:write",
        "mpim:history",
        "search:read.public",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "app_context_changed",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": { "is_enabled": true },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
